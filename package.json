{
  "name": "@iiimaddiniii/remote-objects",
  "version": "0.0.9",
  "description": "A library wich enables the usage of JS-Objects across an communication interface",
  "homepage": "https://github.com/IIIMADDINIII/remote-objects#readme",
  "bugs": {
    "url": "https://github.com/IIIMADDINIII/remote-objects/issues"
  },
  "license": "MIT",
  "author": "IIIMADDINIII <martin@elend.name>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IIIMADDINIII/remote-objects"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./ObjectStore": {
      "import": "./dist/ObjectStore.mjs",
      "require": "./dist/ObjectStore.cjs"
    },
    "./RequestHandler": {
      "import": "./dist/RequestHandler.mjs",
      "require": "./dist/RequestHandler.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260428.1",
    "@vitest/coverage-istanbul": "4.1.4",
    "@vitest/ui": "4.1.4",
    "rolldown-plugin-access-privates": "^0.1.3",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}